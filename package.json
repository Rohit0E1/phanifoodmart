{
  "name": "stockconnect-backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#root/*": "./*",
    "#util/*": "./src/util/*",
    "#models/*": "./src/models/*",
    "#controllers/*": "./src/controllers/*",
    "#routes/*": "./src/routes/*",
    "#service/*": "./src/service/*",
    "#middleware/*": "./src/middleware/*",
    "#validations/*": "./src/validations/*",
    "#config/*": "./src/config/*",
    "#helpers/*": "./src/helpers/*",
    "#utils/*": "./src/util/*",
    "#constants/*": "./src/constants/*"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src --fix",
    "prettier": "prettier . --ignore-path .prettierignore",
    "format:check": "yarn run prettier --check",
    "format:fix": "yarn run prettier --write",
    "format:staged": "pretty-quick --staged",
    "prepare": "husky",
    "postinstall": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.894.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.4",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "tslib": "^2.8.1",
    "uuidv4": "^6.2.13",
    "xml2js": "^0.6.2",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged && yarn run lint",
      "pre-push": "yarn run lint"
    }
  },
  "packageManager": "yarn@4.9.4"
}
